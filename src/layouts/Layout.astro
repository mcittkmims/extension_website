---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A clipboard manager browser extension. Or so it seems." />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <span>Clipboard Manager</span>
        </a>
        <div class="nav-links">
          <a href="#features">Features</a>
          <a href="#demo">Demo</a>
          <a href="#hidden">Under the Surface</a>
          <a href="https://github.com/mcittkmims/extension" class="nav-btn" target="_blank" rel="noopener">Get Extension</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <span>Clipboard Manager v4.2.2</span>
        <a href="https://github.com/mcittkmims/extension" target="_blank" rel="noopener">GitHub</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e4e4e7;
  }

  .nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 14px;
    color: #18181b;
  }

  .nav-brand svg {
    color: #52525b;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 13px;
    color: #71717a;
  }

  .nav-links a:hover {
    color: #18181b;
  }

  .nav-btn {
    padding: 6px 14px;
    background: #18181b;
    color: #fafafa !important;
    border-radius: 6px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .nav-btn:hover {
    background: #3f3f46;
  }

  .footer {
    padding: 20px 24px;
    border-top: 1px solid #e4e4e7;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: #a1a1aa;
  }

  .footer-inner a:hover {
    color: #18181b;
  }

  @media (max-width: 640px) {
    .nav-links a:not(.nav-btn) {
      display: none;
    }
  }
</style>
