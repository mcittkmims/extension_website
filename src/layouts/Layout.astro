---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A clipboard manager browser extension. Or so it seems." />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <span>Clipboard Manager</span>
        </a>
        <div class="nav-links">
          <a href="#features">Features</a>
          <a href="#demo">Demo</a>
          <a href="#hidden">Under the Surface</a>
          <a
            href="https://github.com/chillguysstudio/extension/releases/latest"
            class="nav-btn"
            rel="noopener"
            data-get-extension
          >
            Get Extension
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <span>© {new Date().getFullYear()} Clipboard Manager</span>
        <a href="https://github.com/chillguysstudio/extension" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          GitHub
        </a>
      </div>
    </footer>

    <script>
      const releaseApi = "https://api.github.com/repos/chillguysstudio/extension/releases/latest";
      const fallbackUrl = "https://github.com/chillguysstudio/extension/releases/latest";
      const links = document.querySelectorAll("[data-get-extension]");
      let cachedAsset = null;

      const preferredAsset = (assets) => {
        if (!Array.isArray(assets) || assets.length === 0) return null;
        const scored = assets.map((asset) => {
          const name = String(asset?.name ?? "").toLowerCase();
          let score = 0;
          if (name.endsWith(".xpi")) score = 4;
          else if (name.endsWith(".zip")) score = 3;
          else if (name.endsWith(".crx")) score = 2;
          else score = 1;
          return { asset, score };
        });
        scored.sort((a, b) => b.score - a.score);
        return scored[0]?.asset ?? null;
      };

      const getLatestAsset = async () => {
        if (cachedAsset) return cachedAsset;
        try {
          const response = await fetch(releaseApi, { headers: { Accept: "application/vnd.github+json" } });
          if (!response.ok) return null;

          const release = await response.json();
          const asset = preferredAsset(release?.assets);
          cachedAsset = asset
            ? {
                id: asset.id,
                name: asset.name || "extension-release",
                browser_download_url: asset.browser_download_url,
              }
            : null;
          return cachedAsset;
        } catch {
          return null;
        }
      };

      const applyDownloadLink = async () => {
        const asset = await getLatestAsset();
        const href = asset?.browser_download_url || fallbackUrl;
        const title = asset?.name ? `Download ${asset.name}` : "Download latest extension release";
        links.forEach((link) => {
          link.setAttribute("href", href);
          link.setAttribute("title", title);
          link.removeAttribute("target");
        });
      };

      const triggerBlobDownload = (blob, filename) => {
        const objectUrl = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = objectUrl;
        a.download = filename || "extension-release";
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(() => URL.revokeObjectURL(objectUrl), 30000);
      };

      const downloadLatestRelease = async (event) => {
        event.preventDefault();
        const asset = await getLatestAsset();

        if (!asset?.id) {
          window.location.href = fallbackUrl;
          return;
        }

        try {
          const assetApi = `https://api.github.com/repos/chillguysstudio/extension/releases/assets/${asset.id}`;
          const response = await fetch(assetApi, {
            headers: { Accept: "application/octet-stream" },
          });
          if (!response.ok) throw new Error("Asset download request failed");

          const blob = await response.blob();
          triggerBlobDownload(blob, asset.name);
        } catch {
          window.location.href = asset.browser_download_url || fallbackUrl;
        }
      };

      links.forEach((link) => link.addEventListener("click", downloadLatestRelease));
      applyDownloadLink();
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #e4e4e7;
  }

  .nav-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 14px;
    color: #18181b;
  }

  .nav-brand svg {
    color: #52525b;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 13px;
    color: #71717a;
  }

  .nav-links a:hover {
    color: #18181b;
  }

  .nav-btn {
    padding: 6px 14px;
    background: #18181b;
    color: #fafafa !important;
    border-radius: 6px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .nav-btn:hover {
    background: #3f3f46;
  }

  .footer {
    padding: 20px 24px;
    border-top: 1px solid #e4e4e7;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: #a1a1aa;
  }

  .footer-inner a {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer-inner a:hover {
    color: #18181b;
  }

  @media (max-width: 640px) {
    .nav-links a:not(.nav-btn) {
      display: none;
    }
  }
</style>
